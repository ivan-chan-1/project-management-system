      "get": {
        "tags": [
          "Student Requests"
        ],
        "parameters": [
          {
            "name": "studentId",
            "in": "path",
            "required": true,
            "description": "ID of the student we want details about",
            "type": "bson"
          }
        ],
        "summary": "Returns student object for given studentId",
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request - Incorrect parameter"
          },
          "404": {
            "description": "Not Found - Student does not exist in the database"
          }
        }
      }
    },
    "/api/project/summary/{projectId}": {
      "get": {
        "tags": [
          "Project Requests"
        ],
        "summary": "Returns project background for given projectId",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "ID of the project we want background about",
            "type": "bson"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request - Incorrect parameter"
          },
          "404": {
            "description": "Not Found - Project does not exist in the database"
          }
